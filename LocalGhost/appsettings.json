{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },

  "LocalGhost": {
    "PollIntervalSeconds": 30,

    "GitHub": {
      "Token": "ghp_YOUR_PERSONAL_ACCESS_TOKEN_HERE",
      "RepoOwner": "your-github-username",
      "RepoName": "your-repo-name",
      "Branch": "main"
    },

    "Build": {
      "ApiProjectPath": "C:\\Projects\\YourApp\\YourApp.Api\\YourApp.Api.csproj",
      "ReactProjectPath": "C:\\Projects\\YourApp\\your-react-app",
      "ApiOutputPath": "C:\\LocalGhost\\Builds\\api-output",
      "ReactOutputPath": "C:\\LocalGhost\\Builds\\react-output"
    },

    "IIS": {
      "SitePath": "C:\\inetpub\\wwwroot\\YourApp",
      "AppPoolName": "YourAppPool",
      "BackupPath": "C:\\LocalGhost\\Backups"
    },

    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "you@gmail.com",
      "Password": "your-gmail-app-password",
      "FromAddress": "you@gmail.com",
      "ToAddress": "you@gmail.com",
      "EnableSsl": true,
      "NotifyOnSuccess": true
    }
  }
}